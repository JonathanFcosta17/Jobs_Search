# ============================================
# Jobs Search Agent — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Google Gemini API ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Email Notifications (Gmail SMTP) ---
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
NOTIFICATION_EMAIL=recipient@gmail.com

# --- Job Search Settings ---
SEARCH_LOCATION=Remote
SEARCH_COUNTRY=USA
MIN_MATCH_SCORE=75
RESULTS_PER_SEARCH=25

# --- Database ---
POSTGRES_USER=jobsearch
POSTGRES_PASSWORD=jobsearch_secret
POSTGRES_DB=jobsearch_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://jobsearch:jobsearch_secret@postgres:5432/jobsearch_db

# --- Airflow ---
AIRFLOW_UID=50000
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow
